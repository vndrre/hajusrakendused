{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "outputDirectory": "public/build",
  "routes": [
    {
      "src": "/(.*\\.(?:css|js|mjs|cjs|json|map|png|jpe?g|gif|svg|ico|webp|woff2?|ttf|otf|eot|txt))",
      "dest": "/public/$1"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}

